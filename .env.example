# Copy this file to .env and fill in real values.
# .env is gitignored.

# FRED API key (free) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Google Cloud service-account JSON for GDELT BigQuery (Phase 3)
# Path to a JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=

# Anthropic API key — LLM cluster labelling (Phase 3 `label` stage).
# Create at https://platform.claude.com → Settings → API keys.
# The stage is skipped gracefully if unset.
ANTHROPIC_API_KEY=

# Optional override for the canonical DuckDB path.
# Default is <repo>/data/processed/metals.duckdb.
METALS_DB_PATH=
