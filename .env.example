# Copy this file to .env and fill in real values.
# .env is gitignored.

# FRED API key (free) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Google Cloud service-account JSON for GDELT BigQuery (Phase 3)
# Path to a JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional override for the canonical DuckDB path.
# Default is <repo>/data/processed/metals.duckdb.
METALS_DB_PATH=
