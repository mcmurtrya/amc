# Data: keep structure, ignore contents
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/features/*
!data/features/.gitkeep

# DuckDB
*.duckdb
*.duckdb.wal
*.duckdb.tmp

# Parquet
*.parquet
# ...except the exported eval-harness records: irreplaceable (re-deriving them
# means re-running every model), tiny (~1.3 MB ZSTD), and lost on a
# migrations-only rebuild since runs/run_predictions are created lazily. See
# scripts/export_harness.py and Phase 6.10.
!results/harness_export/*.parquet

# Environment
.env
.venv/
venv/

# Python
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
pytest-cache-files-*/
*.egg-info/
build/
dist/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# uv cache (lockfile IS committed)
.uv-cache/

# Model artifacts
*.pt
*.pth
*.pkl
*.joblib
*.safetensors

# Results — keep .md docs, ignore large outputs
results/figures/
results/checkpoints/
results/embeddings/

# OS
.DS_Store
Thumbs.db
